# Image Embedding Service Configuration
# Model ID = InferenceClient first, then fallback to HF Space URL.
# Default: openai/clip-vit-base-patch32 produces 512-dim vectors (matches image_embedding column).

HF_EMBEDDING_API_URL=openai/clip-vit-base-patch32

# Get your token from: https://huggingface.co/settings/tokens (needs Inference API scope)
HF_API_TOKEN=your_huggingface_api_token_here

# Service Configuration
LOG_LEVEL=INFO
