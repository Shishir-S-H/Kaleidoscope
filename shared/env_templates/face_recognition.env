# Face Recognition Service Configuration
# Uses custom HF Space API (multipart file → JSON {"faces":[...]}); not the huggingface.co/spaces/... browser URL.
# Space: https://huggingface.co/spaces/phantomfury/kaleidoscope-face-recognition

HF_API_URL=https://phantomfury-kaleidoscope-face-recognition.hf.space/detect

# Get your token from: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_api_token_here

# Service Configuration
LOG_LEVEL=INFO
