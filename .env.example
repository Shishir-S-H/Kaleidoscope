# Kaleidoscope AI - Environment Configuration
# Copy this file to .env and fill in the values before running docker-compose.

# --- Required Credentials ---
REDIS_PASSWORD=your_strong_redis_password_here
ELASTICSEARCH_PASSWORD=your_strong_elasticsearch_password_here

# --- Backend App ---
DOCKER_REGISTRY=ajayprabhu2004
APP_VERSION=latest
APP_CONTAINER_NAME=kaleidoscope-app
APP_PORT=8080

# --- AI Platform Selection ---
# Global default platform for all AI services (huggingface, google)
AI_PLATFORM=huggingface

# Per-service overrides (optional — falls back to AI_PLATFORM)
# MODERATION_PLATFORM=huggingface
# TAGGING_PLATFORM=huggingface
# SCENE_PLATFORM=huggingface
# CAPTIONING_PLATFORM=huggingface
# FACE_PLATFORM=huggingface
# EMBEDDING_PLATFORM=huggingface

# --- Google Cloud Configuration (used when AI_PLATFORM=google or per-task *_PLATFORM=google) ---
# GCP project ID — required when any Google provider is active
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GCP region for Vertex AI (defaults to us-central1)
# GOOGLE_CLOUD_REGION=us-central1
# Gemini model override (default: gemini-1.5-flash)
# GOOGLE_GEMINI_MODEL=gemini-1.5-flash
# Vertex AI embedding model override (default: multimodalembedding@001)
# GOOGLE_EMBEDDING_MODEL=multimodalembedding@001
# Safe Search unsafe threshold 0.0-1.0 (default: 0.5 / "POSSIBLE")
# GOOGLE_MODERATION_THRESHOLD=0.5
#
# DigitalOcean / CI deployment — Base64-encoded service account JSON key.
# Set this ONLY on the server directly (never commit the actual value).
# Generate: base64 -w 0 your-service-account-key.json
# GOOGLE_CREDENTIALS_BASE64=

# --- HuggingFace Configuration (used when platform=huggingface) ---
# Get a token with "Inference API" scope at https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_api_token_here

# Model IDs use HuggingFace Inference first; providers fall back to HF_*_SPACE_URL if inference fails.
# Tagger: ImageNet-style labels. Scene: Places365-style labels. Embedding: keep 512-dim CLIP for ES mapping.
HF_MODERATION_API_URL=Falconsai/nsfw_image_detection
HF_TAGGING_API_URL=facebook/convnext-base-384-22k-1k
HF_SCENE_API_URL=corenet-community/places365-224x224-vit-base
HF_CAPTIONING_API_URL=Salesforce/blip2-opt-2.7b
# Face: custom Space API only — must be *.hf.space/... (multipart file → JSON faces[]), not huggingface.co/spaces/...
# Space: https://huggingface.co/spaces/phantomfury/kaleidoscope-face-recognition
# Optional dev-only override: HF_FACE_API_URL=https://...

# Optional: override Space fallback URL when using model IDs (defaults: phantomfury-kaleidoscope-* Spaces)
# HF_MODERATION_SPACE_URL=https://phantomfury-kaleidoscope-content-moderation.hf.space/classify
# HF_TAGGER_SPACE_URL=https://phantomfury-kaleidoscope-image-tagger.hf.space/tag
# HF_SCENE_SPACE_URL=https://phantomfury-kaleidoscope-scene-recognition.hf.space/recognize
# HF_CAPTIONING_SPACE_URL=https://phantomfury-kaleidoscope-image-captioning.hf.space/caption

# Production compose uses these variable names:
HF_API_URL_CONTENT_MODERATION=Falconsai/nsfw_image_detection
HF_API_URL_IMAGE_TAGGER=facebook/convnext-base-384-22k-1k
HF_API_URL_SCENE_RECOGNITION=corenet-community/places365-224x224-vit-base
HF_API_URL_IMAGE_CAPTIONING=Salesforce/blip2-opt-2.7b
# API endpoint for Space https://huggingface.co/spaces/phantomfury/kaleidoscope-face-recognition (not the /spaces/ UI URL).
HF_API_URL_FACE_RECOGNITION=https://phantomfury-kaleidoscope-face-recognition.hf.space/detect
# Image embedding: CLIP model ID (512-dim) for Elasticsearch image_embedding; avoid clip-vit-large-* without reindexing.
HF_API_URL_IMAGE_EMBEDDING=openai/clip-vit-base-patch16

# Face embedding dimensionality expected by face_recognition / profile_enrollment / face_matcher.
# Must match the ES index mapping dims for known_faces_index and face_search.
# Set to 32 only if your face API genuinely returns 32-dim vectors AND you update both ES mappings.
FACE_EMBEDDING_DIM=1024

# --- Database (used by es_sync and backend app) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kaleidoscope
# DB_USERNAME=postgres
# DB_PASSWORD=your_db_password
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kaleidoscope
