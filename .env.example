# Kaleidoscope AI - Environment Configuration
# Copy this file to .env and fill in the values before running docker-compose.
# AI platform is now Google Cloud. HuggingFace variables are deprecated and unused.

# --- Required Credentials ---
REDIS_PASSWORD=your_strong_redis_password_here
ELASTICSEARCH_PASSWORD=your_strong_elasticsearch_password_here

# --- Backend App ---
DOCKER_REGISTRY=ajayprabhu2004
APP_VERSION=latest
APP_CONTAINER_NAME=kaleidoscope-app
APP_PORT=8080

# --- AI Platform Selection ---
# All AI workers are wired to Google Cloud. This must be set to "google".
AI_PLATFORM=google

# Per-service platform overrides are hardcoded to "google" in docker-compose.prod.yml.
# The variables below are provided for reference only; they are not read by the production compose.
# MODERATION_PLATFORM=google
# TAGGING_PLATFORM=google
# SCENE_PLATFORM=google
# CAPTIONING_PLATFORM=google
# FACE_PLATFORM=google
# EMBEDDING_PLATFORM=google

# --- Google Cloud Configuration (REQUIRED) ---
# GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GCP region for Vertex AI
GOOGLE_CLOUD_REGION=us-central1
# Gemini model used by tagger, scene recognition, and captioning
GOOGLE_GEMINI_MODEL=gemini-1.5-flash
# Vertex AI multimodal embedding model (produces 1408-dim vectors)
GOOGLE_EMBEDDING_MODEL=multimodalembedding@001
# Safe Search threshold — faces/content flagged at or above this level are marked unsafe (0.0–1.0)
GOOGLE_MODERATION_THRESHOLD=0.5
#
# Base64-encoded Google credentials JSON (authorized_user or service account).
# Set this on the server directly — NEVER commit the actual value.
# Generate: base64 -w 0 credentials.json   (Linux)
#           base64 credentials.json         (macOS)
GOOGLE_CREDENTIALS_BASE64=

# --- Database (used by es_sync and backend app) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kaleidoscope
# DB_USERNAME=postgres
# DB_PASSWORD=your_db_password
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_db_password

# --- DEPRECATED: HuggingFace (no longer used) ---
# The following variables are no longer referenced by any service.
# They are kept here for reference only and can be safely removed.
# HF_API_TOKEN=
# HF_API_URL_CONTENT_MODERATION=
# HF_API_URL_IMAGE_TAGGER=
# HF_API_URL_SCENE_RECOGNITION=
# HF_API_URL_IMAGE_CAPTIONING=
# HF_API_URL_FACE_RECOGNITION=
# HF_API_URL_IMAGE_EMBEDDING=
# FACE_EMBEDDING_DIM=
