@@ -315,4 +321,39 @@ public class FaceDetectionConsumer implements StreamListener<String, MapRecord<S
             mediaAiInsightsRepository.save(mediaAiInsights);
         }
     }
+
+    /**
+     * Append {@code face_detection} to {@code services_completed} without racing ML insight updates.
+     * Each attempt loads a fresh entity and runs in its own transaction.
+     */
+    private void appendFaceDetectionServiceCompletedWithRetry(Long mediaId) {
+        final int maxAttempts = 15;
+        for (int attempt = 1; attempt <= maxAttempts; attempt++) {
+            try {
+                transactionTemplate.executeWithoutResult(status -> {
+                    MediaAiInsights fresh = mediaAiInsightsRepository.findByMediaId(mediaId)
+                            .orElseThrow(() -> new IllegalStateException(
+                                    "MediaAiInsights missing while appending face_detection for mediaId=" + mediaId));
+                    appendServiceCompleted(fresh, "face_detection");
+                });
+                return;
+            } catch (OptimisticLockingFailureException ex) {
+                log.warn("Optimistic lock while appending face_detection for mediaId={}, attempt={}/{} — retrying",
+                        mediaId, attempt, maxAttempts);
+                sleepBackoffMs(attempt);
+            }
+        }
+        log.error("Giving up appending face_detection to services_completed for mediaId={} after {} attempts. "
+                        + "Faces are already persisted; reconcile services_completed if needed.",
+                mediaId, maxAttempts);
+    }
+
+    private static void sleepBackoffMs(int attempt) {
+        long delayMs = Math.min(2000L, 50L * attempt * attempt);
+        try {
+            Thread.sleep(delayMs);
+        } catch (InterruptedException ie) {
+            Thread.currentThread().interrupt();
+        }
+    }
 }
