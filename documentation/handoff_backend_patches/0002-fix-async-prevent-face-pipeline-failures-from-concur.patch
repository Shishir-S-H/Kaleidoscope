+    /**
+     * Flat list of per-service insight dicts — matches post_aggregator._merge_media_entry expectations.
+     */
+    private String buildMediaInsightsSnapshot(List<Long> allMediaIds) throws JsonProcessingException {
+        List<Map<String, Object>> entries = new ArrayList<>();
+        for (Long mediaId : allMediaIds) {
+            Optional<MediaAiInsights> opt = mediaAiInsightsRepository.findByMediaId(mediaId);
+            if (opt.isEmpty()) {
+                continue;
+            }
+            MediaAiInsights ai = opt.get();
+            String mid = String.valueOf(mediaId);
+            String mediaUrl = resolveMediaUrl(ai);
+
+            Map<String, Object> moderation = new LinkedHashMap<>();
+            moderation.put("mediaId", mid);
+            moderation.put("service", "moderation");
+            moderation.put("isSafe", Boolean.TRUE.equals(ai.getIsSafe()));
+            moderation.put("mediaUrl", mediaUrl != null ? mediaUrl : "");
+            entries.add(moderation);
+
+            Map<String, Object> tagging = new LinkedHashMap<>();
+            tagging.put("mediaId", mid);
+            tagging.put("service", "tagging");
+            tagging.put("tags", ai.getTags() != null ? Arrays.asList(ai.getTags()) : List.of());
+            entries.add(tagging);
+
+            Map<String, Object> scenes = new LinkedHashMap<>();
+            scenes.put("mediaId", mid);
+            scenes.put("service", "scene_recognition");
+            scenes.put("scenes", ai.getScenes() != null ? Arrays.asList(ai.getScenes()) : List.of());
+            entries.add(scenes);
+
+            Map<String, Object> caption = new LinkedHashMap<>();
+            caption.put("mediaId", mid);
+            caption.put("service", "image_captioning");
+            caption.put("caption", ai.getCaption() != null ? ai.getCaption() : "");
+            entries.add(caption);
+
+            if (ai.getImageEmbedding() != null && !ai.getImageEmbedding().isBlank()) {
+                Map<String, Object> emb = new LinkedHashMap<>();
+                emb.put("mediaId", mid);
+                emb.put("service", "image_embedding");
+                emb.put("hasEmbedding", true);
+                entries.add(emb);
+            }
+        }
+        return objectMapper.writeValueAsString(entries);
+    }
+
+    private static String resolveMediaUrl(MediaAiInsights ai) {
+        try {
+            PostMedia pm = ai.getPostMedia();
+            if (pm == null) {
+                return "";
+            }
+            return pm.getMediaUrl() != null ? pm.getMediaUrl() : "";
+        } catch (Exception e) {
+            return "";
+        }
+    }
+}
